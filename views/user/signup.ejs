<% layout("./listings/boilerplate") %>


<body>
    
    <div class="row">

        <form method="post" action="/signup" class="col-6 offset-3 needs-validation" novalidate >

            <div class="mb-3">
                <label for="username" class="form-label">username</label>
                <input 
                type="text" 
                placeholder="" 
                name="username" 
                class="form-control" required>
                <div class="valid-feedback">
                    Looks good!
                  </div>
                <div class="invalid-feedback">
                    Enter Title!
                  </div>
                </div>

                <div class="mb-3">
                    <label for="email" class="form-label">Email</label>
                    <input 
                    type="email" 
                    placeholder="" 
                    name="email" 
                    class="form-control" required>
                    <div class="valid-feedback">
                        Looks good!
                      </div>
                    <div class="invalid-feedback">
                        Enter Title!
                      </div>
                    </div>

                    <div class="mb-3">
                        <label for="username" class="form-label">password</label>
                        <input 
                        type="password" 
                        placeholder="" 
                        name="password" 
                        class="form-control" required>
                        <div class="valid-feedback">
                            Looks good!
                          </div>
                        <div class="invalid-feedback">
                            Enter Title!
                          </div>
                        </div>

                <button class="btn btn-success">SignUp</button>
        </form>

    </div>

</body>