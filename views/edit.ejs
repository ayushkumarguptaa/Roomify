<% layout("./listings/boilerplate.ejs") %>
<body>
    <div class="row">
        <div class="col-8 offset-2 pt-3 pb-3">
            <h3>Edit Your Listing</h3>
    <form method="post" action="/listings/<%= listing._id%>?_method=PUT" novalidate class="needs-validation">
        <div class="mb-3">
            <label for="title" class="form-label">Title</label>
            <input name="listings[title]" type="text" value="<%= listing.title %>" class="form-control" required>
            <div class="valid-feedback">
                Looks good!
              </div>
              <div class="invalid-feedback">
                Enter title!
              </div>
        </div>
        <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <textarea name="listings[description]" type="text" class="form-control" required><%= listing.description %></textarea>
            <div class="valid-feedback">
                Looks good!
              </div>
              <div class="invalid-feedback">
                Enter Description!
              </div>
        </div>
        <div class="mb-3">
            <label for="image" class="form-label">Image Link</label>
            <input type="text" value="<%= listing.image %>" name="listings[image]" class="form-control" required>
        </div>
        <div class="row">
            <div class="mb-3 col-md-4">
                <label for="price" class="form-label">Price</label>
                <input type="number" name="listings[price]" value="<%= listing.price %>" class="form-control" required>
                <div class="valid-feedback">
                    Looks good!
                  </div>
                  <div class="invalid-feedback">
                    Enter Price!
                  </div>
            </div>
            <div class="mb-3 col-md-8">
                <label for="country" class="form-label">Country</label>
                <input type="text" name="listings[country]" value="<%= listing.country %>" class="form-control" required>
                <div class="valid-feedback">
                    Looks good!
                  </div>
                  <div class="invalid-feedback">
                    Enter Country!
                  </div>
            </div>
        </div>
        <div class="mb-3">
            <label for="location" class="form-label">Location</label>
            <input type="text" value="<%= listing.location %>" name="listings[location]" class="form-control" required>
            <div class="valid-feedback">
                Looks good!
              </div>
              <div class="invalid-feedback">
                Enter Location!
              </div>
        </div>
        <button class="btn btn-dark">Add</button>
    </form>
</div>
</div>
</body>