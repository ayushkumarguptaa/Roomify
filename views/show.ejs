<% layout("/listings/boilerplate") %>
<body>
    <div class="row pt-3 mb-3">
    <div class="col-6 offset-2">
        <h3><b><%= listing.title %></b></h3>
    </div>
        <div class="card col-8 offset-2 listing-card" style="width: 18rem;">
            <img src="<%= listing.image %>" class="card-img-top show-img" alt="...">
            <div class="card-body">
              <p class="card-text">
                <br>
                <%=listing.description%> <br>
                &#8377; <%=listing.price.toLocaleString("en-IN")%> <br>
                <%=listing.location%> <br>
                <%=listing.coutry%> <br>
              </p>
            </div>
    </div>
    <div class="btns form-label">
        <a href="/listings/<%= listing._id%>/edit" class="btn btn-dark col-2 offset-2">Edit</a>
        <form method="post" action="/listings/<%= listing._id%>?_method=DELETE">
            <button class="btn btn-dark offset-2">Delete</button>
        </form>
    </div>
    <!-- Reviews -->

    

    <hr>
    <div class="col-8 offset-2">

        <fieldset class="starability-slot">
  <legend>First rating:</legend>
  <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="0" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="rating" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="rating" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="rating" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="rating" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="rating" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>

        <h4>Leave Reviews</h4>
        <form method="post" action="/listings/<%= listing.id %>/reviews" novalidate class="needs-validation">
            
            <div >
                <label for="rating" class="form-label">Rate</label>
                <input type="range" name="reviews[rating]" min="1" max="5" class="form-range">
            </div>
    
            <div >
                <label for="comment" class="form-label">Comment</label>
                <textarea name="reviews[comment]" id="" class="form-control" rows="5" required></textarea>
                <div class="valid-feedback">
                    Good!!
                </div>
                <div class="invalid-feedback">
                    please give feedback!!
                </div>
            </div>
            <br>
            <button type="submit" class="btn btn-outline-dark">SUBMIT</button>
        </form>

<!-- reviews list -->
            <div class=" row mt-3">
               <% for(review of listing.reviews){ %>
                <div class="card col-5 mb-3 ms-3">
                    <div class="card-body">
                      <h5 class="card-title">jane</h5>
                      <h6 class="card-subtitle mb-2 text-body-secondary"><%= review.comment %></h6>
                      <p class="card-text"> <%= review.rating %> Stars</p>
                      <p class="starability-result" data-rating="<%= review.rating %>" >Rated: 3 stars</p>
                      <form method="post" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                        <button class="btn btn-sm btn-dark mb-3">Delete</button>
                      </form>
                    </div>
                  </div>
                <% } %>
    
            </div>
        </div>

    </div>
</body>
